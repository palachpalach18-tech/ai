	shared.AlSploitAutowinTable = AlSploitAutowinTable
	BedwarsRemotes.JoinQueueRemote:FireServer({queueType = "bedwars_lucky_block_to2"})
end

local function GetMatchState()
	return ClientStore:getState().Game.matchState
end

local function IsAlive(Player)
	if not Player.Character then return false end
	if not Player.Character:FindFirstChildOfClass("Humanoid") then return false end
	if Player.Character:GetAttribute("Health") <= 0 then return false end
	if not Player.Character.PrimaryPart then return false end	

	return true
end	

local function Autowin()
	local function FindNearestIronDrop(MaxDistance)
		local NearestIronDistance = MaxDistance or math.huge
		local NearestIron

		for i, v in next, WorkSpace:FindFirstChild("ItemDrops"):GetChildren() do
			if v.Name == "iron" then
				local Distance = (v.Position - LocalPlayer.Character.PrimaryPart.Position).Magnitude

				if Distance < NearestIronDistance then
					NearestIronDistance = Distance
					NearestIron = v
				end
			end
		end

		return NearestIron, NearestIronDistance
	end
	
	local function TeleportEfficiently(StartPosition, EndPosition)
		local Distance = (EndPosition - StartPosition).Magnitude

		local AdvantageousStrategy

		if Distance < AnticheatConstants.MAX_IDLE_TELEPORT_DISTANCE and (AnticheatConstants.MIN_IDLE_BEFORE_TELEPORT + 0.1) <= Distance / AnticheatConstants.MAX_CONTINUOUS_SPEED then	
			LocalPlayer.Character.PrimaryPart.Anchored = true

			task.wait(AnticheatConstants.MIN_IDLE_BEFORE_TELEPORT)

			LocalPlayer.Character.PrimaryPart.Anchored = false

			local TweenInformation = TweenInfo.new(0.1, Enum.EasingStyle.Linear, Enum.EasingDirection.Out, 0, false, 0)
			local MouseTpTween = TweenService:Create(LocalPlayer.Character.PrimaryPart, TweenInformation, {CFrame = CFrame.new(EndPosition)})

			MouseTpTween:Play()
		else
			local StartPosition = LocalPlayer.Character.PrimaryPart.Position
			local LookDirection = EndPosition - StartPosition

			local Distance = LookDirection.Magnitude
			local Direction = LookDirection.Unit

			local MaxSpeed = AnticheatConstants.MAX_CONTINUOUS_SPEED
			local MaxTime = AnticheatConstants.MAX_CONTINUOUS_FLY_TIME

			local MaxDistanceByTime = MaxSpeed * MaxTime
			local TravelDistance = math.min(Distance, MaxDistanceByTime)

			local TweenTime = TravelDistance / MaxSpeed

			TweenTime = math.min(TweenTime, MaxTime)

			local TargetPosition = StartPosition + (Direction * TravelDistance)

			local TweenInformation = TweenInfo.new(
				TweenTime,
				Enum.EasingStyle.Linear,
				Enum.EasingDirection.Out
			)

			local MouseTpTween = TweenService:Create(
				LocalPlayer.Character.PrimaryPart,
				TweenInformation,
				{CFrame = CFrame.new(TargetPosition)}
			)

			MouseTpTween:Play()
		end
	end

	local function GetDevidedPosition(Position)
		local X = math.round(Position.X / 3)
		local Y = math.round(Position.Y / 3)
		local Z = math.round(Position.Z / 3)

		return Vector3.new(X, Y, Z)
	end
	
	local function FindNearestNpc(MaxDistance)
		local MaxDistance = MaxDistance or math.huge
		local NearestNpc = nil

		task.spawn(function()
			for i, v in next, CollectionService:GetTagged("BedwarsTeamUpgrader") do
				local Distance = (v.Position - LocalPlayer.Character.PrimaryPart.Position).Magnitude

				if Distance < MaxDistance then
					MaxDistance = Distance
					NearestNpc = v
				end
			end
		end)

		task.spawn(function()
			for i, v in next, CollectionService:GetTagged("BedwarsItemShop") do
				local Distance = (v.Position - LocalPlayer.Character.PrimaryPart.Position).Magnitude

				if Distance < MaxDistance then
					MaxDistance = Distance
					NearestNpc = v		
				end
			end
		end)

		return NearestNpc
	end
	
	local function FindNearestBed(MaxDistance, ExcludeLocalPlayer)
		local NearestBedDistance = MaxDistance or math.huge
		local NearestBed = nil

		for i, v in next, CollectionService:GetTagged("bed") do
			local BedColor = (v:FindFirstChild("Bed") and v:FindFirstChild("Bed").BrickColor or v:FindFirstChild("bed"):FindFirstChild("Bed") and v:FindFirstChild("bed"):FindFirstChild("Bed").BrickColor or nil)

			if BedColor and (not ExcludeLocalPlayer or BedColor ~= LocalPlayer.Team.TeamColor) then
				local Distance = (v.Position - LocalPlayer.Character.PrimaryPart.Position).Magnitude

				if Distance < NearestBedDistance then
					NearestBedDistance = Distance
					NearestBed = v
				end
			end
		end

		return NearestBed, NearestBedDistance
	end
	
	local function GetIronAmount(Player)
		for i, v in next, LocalPlayer.Character:FindFirstChild("InventoryFolder").Value:GetChildren() do
			if v.Name == "iron" then
				return v:GetAttribute("Amount")
			end
		end
		
		return 0
	end
	
	local function GetBlock()
		for i, v in next, LocalPlayer.Character:FindFirstChild("InventoryFolder").Value:GetChildren() do
			if v.Name:find("wool") then
				return v.Name
			end
		end
	end
	
	local NearestIronDrop = FindNearestIronDrop()
	
	if NearestIronDrop then
		TeleportEfficiently(LocalPlayer.Character.PrimaryPart.Position, NearestIronDrop.Position + Vector3.new(0, 3, 0))
	end
	
	task.wait(1)
	
	local NearestBed, NearestBedDistance = FindNearestBed(math.huge, true)
	
	if NearestBed then
		local WoolStacksRequired = math.round(NearestBedDistance / 3 / 16)
		
		repeat task.wait() until GetIronAmount() >= WoolStacksRequired * 8
		
		local NearestNpc = FindNearestNpc()
		
		if NearestNpc then
			TeleportEfficiently(LocalPlayer.Character.PrimaryPart.Position, NearestNpc.Position + Vector3.new(0, 3, 0))
			
			repeat
				task.wait()
				
				BedwarsRemotes.BedwarsPurchaseItemRemote:InvokeServer(
					{
						shopItem = {
							currency = "iron",
							itemType = "wool_white",
							amount = 16,
							price = 8,
							disabledInQueue = {
								"mine_wars"
							},
							category = "Blocks"
						},
						shopId = NearestNpc.Name or ""
					}
				)
			until not GetIronAmount() or GetIronAmount() < 8
			
			TeleportEfficiently(LocalPlayer.Character.PrimaryPart.Position, NearestNpc.Position + Vector3.new(0, 3, 0))	
			
			local LocalPlayerBed = FindNearestBed(math.huge, false)
			
			if LocalPlayerBed then
				TeleportEfficiently(LocalPlayer.Character.PrimaryPart.Position, LocalPlayerBed.Position)

				task.wait(1)

				LocalPlayer.Character.Humanoid:MoveTo(NearestBed.Position)

				task.spawn(function()
					repeat
						task.wait()

						LocalPlayer.Character.Humanoid:MoveTo(NearestBed.Position)

						for i = 1, 3 do
							local BuildPosition = (LocalPlayer.Character.PrimaryPart.Position + ((LocalPlayer.Character.PrimaryPart.CFrame.LookVector * i) - Vector3.new(0, (LocalPlayer.Character.PrimaryPart.Size.Y / 2) + ((LocalPlayer.Character.Humanoid.HipHeight + (LocalPlayer.Character.Humanoid.HipHeight / 2))), 0)))
							local RealBuildPosition = GetDevidedPosition(BuildPosition)
							local Block = GetBlock()

							if Block then
								BedwarsRemotes.BlockPlacingRemote:InvokeServer({blockType = Block, blockData = 0, position = RealBuildPosition})
							end
						end
					until not game
				end)
				
				task.spawn(function()
					repeat
						task.wait(0.5)

						for i = 1, 10 do
							task.wait(0.1)
							
							BedwarsRemotes.DamageBlockRemote:InvokeServer(
								{
									blockRef = {
										blockPosition = GetDevidedPosition(FindNearestBed(math.huge, true).Position)
									},
									hitPosition = FindNearestBed(math.huge, true).Position,
									hitNormal = Vector3.yAxis
								}
							)
						end
					until not game
				end)
				
				repeat task.wait() until GetMatchState() == 2
				
				TeleportToGame()
			end
		end
	end
end

